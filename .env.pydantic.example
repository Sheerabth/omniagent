# Pydantic AI — multi-provider harness
# Copy to .env.pydantic and fill in keys for the providers you use.
# All vars in this file are loaded into the worker process environment at runtime.
# Pydantic AI auto-detects the model class from the provider prefix in the model string.

# OpenAI — openai:gpt-4o, openai:o4-mini, etc.
OPENAI_API_KEY=

# Anthropic — anthropic:claude-sonnet-4-6, etc.
ANTHROPIC_API_KEY=

# Groq — groq:llama-4-maverick, etc.
GROQ_API_KEY=

# Mistral — mistral:mistral-large-latest, etc.
MISTRAL_API_KEY=

# DeepSeek — deepseek:deepseek-chat
DEEPSEEK_API_KEY=

# Google Gemini — google:gemini-2.5-flash, etc.
GEMINI_API_KEY=

# Add any other provider env var below — Pydantic AI picks it up automatically.
# Full list: https://ai.pydantic.dev/models/
