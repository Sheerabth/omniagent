DATABASE_URL=postgresql://omniagent:omniagent@localhost:5432/omniagent

# Fernet key for encrypting auth_context — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OMNIAGENT_ENCRYPTION_KEY=

# UI admin password — required to access the web UI
UI_PASSWORD=changeme

# LLM provider keys (set whichever harness(es) you use)
OMNIAGENT_CLAUDE_API_KEY=
OMNIAGENT_ANTIGRAVITY_API_KEY=

# Langfuse tracing (optional — LLM observability, no-op if unset)
# Quick start: sign up at https://cloud.langfuse.com (free: 50K obs/mo)
# Self-hosted: docker compose -f docker-compose.yml -f docker-compose.langfuse.yml up -d
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com  # or http://localhost:3000 for self-hosted
# NOTE: use LANGFUSE_BASE_URL, not LANGFUSE_HOST — empty HOST overrides the cloud default

# Tuning (optional)
MAX_HISTORY_TURNS=50
TOOL_EXECUTION_TIMEOUT=30
MONTY_EXECUTION_TIMEOUT=30
MONTY_EXECUTOR_WORKERS=4
WORKER_CONCURRENCY=10
LOG_LEVEL=INFO
