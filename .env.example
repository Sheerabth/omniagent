DATABASE_URL=postgresql://omniagent:omniagent@localhost:5432/omniagent

# Fernet key for encrypting auth_context — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OMNIAGENT_ENCRYPTION_KEY=

# Fixed API key for the built-in UI (optional — auto-generated if unset, printed on startup)
OMNIAGENT_API_KEY=

# LLM provider keys (set whichever harness(es) you use)
OMNIAGENT_CLAUDE_API_KEY=
OMNIAGENT_ANTIGRAVITY_API_KEY=

# Tuning (optional)
MAX_HISTORY_TURNS=50
TOOL_EXECUTION_TIMEOUT=30
MONTY_EXECUTION_TIMEOUT=30
MONTY_EXECUTOR_WORKERS=4
