# Claude / Anthropic-compatible provider (DeepSeek, etc.)
# Copy to .env.claude and fill in your values.

# API key — standard Anthropic env var (x-api-key header)
ANTHROPIC_API_KEY=

# Auth token — used as Bearer token when ANTHROPIC_BASE_URL is set to a
# third-party provider (e.g. DeepSeek). Only one of API_KEY or AUTH_TOKEN
# is typically needed.
ANTHROPIC_AUTH_TOKEN=

# Base URL — set only for third-party Anthropic-compatible endpoints.
# Leave empty for api.anthropic.com.
ANTHROPIC_BASE_URL=

# Model routing (optional — model is also configurable per-agent in the UI)
# ANTHROPIC_MODEL=
# ANTHROPIC_DEFAULT_OPUS_MODEL=
# ANTHROPIC_DEFAULT_SONNET_MODEL=
# ANTHROPIC_DEFAULT_HAIKU_MODEL=
# CLAUDE_CODE_SUBAGENT_MODEL=
